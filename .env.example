# Polymarket CLOB endpoint
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_DATA_API_URL=https://data-api.polymarket.com
POLY_CHAIN_ID=137

# Wallet / account configuration
# POLY_PRIVATE_KEY=0xyour_private_key
# POLY_FUNDER=0xyour_funder_or_proxy_wallet
# POLY_USER_ADDRESS=0xyour_profile_or_proxy_wallet
# POLY_SIGNATURE_TYPE=2

# Optional proxy configuration for local debugging in a reachable network
# POLY_HTTP_PROXY=http://127.0.0.1:7890
# POLY_HTTPS_PROXY=http://127.0.0.1:7890
# POLY_NO_PROXY=localhost,127.0.0.1

# Optional pre-derived API credentials
# POLY_API_KEY=your_api_key
# POLY_API_SECRET=your_api_secret
# POLY_API_PASSPHRASE=your_api_passphrase

# Notes
# - For proxy wallets, POLY_FUNDER should be your Polymarket proxy wallet address.
# - POLY_USER_ADDRESS is used for the official public positions endpoint. If omitted, the CLI falls back to POLY_FUNDER.
# - POLY_HTTP_PROXY / POLY_HTTPS_PROXY are mapped to standard HTTP(S)_PROXY env vars so both the official positions API and py-clob-client can use them.
# - If API credentials are omitted, the client will attempt to derive them from the private key.
# - The current CLI supports breakeven stop, fixed stop-loss, fixed take-profit, and trailing take-profit.
