# Polymarket CLOB endpoint
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_DATA_API_URL=https://data-api.polymarket.com
POLY_CHAIN_ID=137

# Wallet / account configuration
# POLY_FUNDER=0xyour_funder_or_proxy_wallet
# POLY_SIGNATURE_TYPE=2
# Optional: force secret-store backend
# POLY_SECRET_STORE_BACKEND=dpapi
# POLY_SECRET_STORE_BACKEND=tpm2
# POLY_SECRET_STORE_BACKEND=keyring

# Optional local UI auth
# POLY_UI_USERNAME=admin
# POLY_UI_PASSWORD=change-me

# Optional Telegram bot controls
# Telegram bot token is NOT read from .env.
# Save it to the local encrypted store with:
#   poetry run poly-shield secrets set-telegram-bot-token
# POLY_TELEGRAM_ENABLED=true
# Comma-separated Telegram numeric user IDs from message.from.id
# POLY_TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# Optional poll/retry interval in seconds; default is 5
# POLY_TELEGRAM_POLL_INTERVAL_SECONDS=5

# Optional proxy configuration for local debugging in a reachable network
# POLY_HTTP_PROXY=http://127.0.0.1:7890
# POLY_HTTPS_PROXY=http://127.0.0.1:7890
# POLY_NO_PROXY=localhost,127.0.0.1

# Optional pre-derived API credentials
# POLY_API_KEY=your_api_key
# POLY_API_SECRET=your_api_secret
# POLY_API_PASSPHRASE=your_api_passphrase

# Notes
# - For proxy wallets, POLY_FUNDER should be your Polymarket proxy wallet address.
# - Private key is loaded only from local secret store (set via: poetry run poly-shield secrets set-private-key)
# - Telegram bot token is also loaded only from local secret store, not from .env
# - Telegram bot requires both POLY_TELEGRAM_ENABLED=true and a non-empty POLY_TELEGRAM_ALLOWED_USER_IDS
# - user address is derived automatically:
#   - signature_type=1/2 -> POLY_FUNDER
#   - signature_type=0 or unset -> signer address derived from private key
# - secret-store backend default is: Windows=dpapi, Linux=tpm2
# - Linux tpm2 backend requires package: tpm2-tools
